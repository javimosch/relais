// HTTP routing. TLS terminates at the proxy.

func pathof(req) (p) {
    parts := split(req.path, "?")
    p = parts[0]
}

func handle(req) (res) {
    p := pathof(req)
    if p == "/_health" { res = ok_json("{\"ok\":1,\"version\":\"" + app_version() + "\"}")  return }
    // the public catch endpoint accepts ANY method
    if has_prefix(p, "/c/") { res = handle_catch(req)  return }
    if req.method == "POST" && p == "/v1/inboxes" { res = handle_inbox_create(req)  return }
    if req.method == "GET" && p == "/v1/messages" { res = handle_messages(req)  return }
    if req.method == "DELETE" && p == "/v1/messages" { res = handle_messages_clear(req)  return }
    if req.method == "GET" && p == "/v1/wait" { res = handle_wait(req)  return }
    if req.method == "DELETE" && p == "/v1/inbox" { res = handle_inbox_delete(req)  return }
    if p == "/llms.txt" { res = ok_text(llms_txt(public_url(req)))  return }
    if p == "/guide" { res = ok_json(guide_json(public_url(req)))  return }
    if p == "/" { res = ok_html(landing_html())  return }
    res = not_found()
}

func run_server(port) {
    db := db_open()
    db_migrate(db)
    sqlite_close(db)
    set_trust_proxy(1)
    set_access_log(1)
    set_max_body(131072)
    set_read_timeout(60000)   // long enough for /v1/wait long-polls
    write(2, "{\"event\":\"listening\",\"port\":" + str(port) + "}\n")
    serve(port, func(req) { return handle(req) })
}
